<!DOCTYPE html>
<html lang="{{ get_locale() }}">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="{{ url_for('static', filename='styles.css') }}">
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    <title>Redémarrage en cours - Pimmich</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            color: white;
        }

        .container {
            text-align: center;
            padding: 40px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 20px;
            backdrop-filter: blur(10px);
            box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.37);
            max-width: 500px;
        }

        h1 {
            font-size: 2em;
            margin-bottom: 20px;
            font-weight: 600;
        }

        .status {
            font-size: 1.2em;
            margin-bottom: 10px;
            opacity: 0.9;
        }

        .status-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: rgba(255, 255, 255, 0.05);
            padding: 12px 20px;
            border-radius: 10px;
            margin-top: 10px;
        }

        /* Spinner animé - ORIGINAL */
        .spinner {
            width: 60px;
            height: 60px;
            margin: 0 auto 30px;
            border: 6px solid rgba(255, 255, 255, 0.3);
            border-top: 6px solid white;
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }

        @keyframes spin {
            0% {
                transform: rotate(0deg);
            }

            100% {
                transform: rotate(360deg);
            }
        }

        /* Animation de pulsation pour le texte - ORIGINAL */
        .pulse {
            animation: pulse 2s ease-in-out infinite;
        }

        @keyframes pulse {

            0%,
            100% {
                opacity: 1;
            }

            50% {
                opacity: 0.5;
            }
        }

        .info {
            font-size: 0.9em;
            opacity: 0.7;
            margin-top: 30px;
        }

        /* Progress bar à 50s */
        .progress-bar {
            width: 100%;
            height: 4px;
            background: rgba(255, 255, 255, 0.2);
            border-radius: 2px;
            overflow: hidden;
            margin-top: 20px;
        }

        .progress-bar-fill {
            height: 100%;
            background: white;
            animation: progress 50s ease-out forwards;
        }

        @keyframes progress {
            0% {
                width: 0%;
            }

            100% {
                width: 90%;
            }
        }

        /* Compteur bien visible */
        .countdown {
            font-size: 2.5em;
            font-weight: bold;
            color: white;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.5);
            margin: 20px 0;
            font-family: 'Courier New', monospace;
            animation: pulse 1.5s ease-in-out infinite;
        }
    </style>
</head>

<body>
    <div class="container">
        <!-- Logo Pimmich - ORIGINAL -->
        <img src="{{ url_for('static', filename='pimmich_logo.png') }}" alt="Logo Pimmich"
            style="width: 160px; height: auto;">

        <h1>Redémarrage en cours</h1>

        <div class="spinner"></div>

        <!-- STATUS + COMPTEUR SÉPARÉS -->
        <div id="status-container" class="space-y-3 mb-6">
            <div class="status-row">
                <span>Serveur Web</span>
                <i id="icon-server" class="fas fa-circle text-red-500"></i>
            </div>
            <div class="status-row">
                <span>Diaporama</span>
                <i id="icon-slideshow" class="fas fa-circle text-red-500"></i>
            </div>
        </div>

        <div id="countdown" class="countdown">60s</div>

        <div class="progress-bar">
            <div class="progress-bar-fill"></div>
        </div>

        <p class="info">
            Le système applique les changements.<br>
            Cette page se rechargera automatiquement une fois le système prêt.
        </p>
    </div>

    <script>
        let rebootTriggered = false;
        let remainingTime = 60;
        const urlParams = new URLSearchParams(window.location.search);
        const oldInstance = urlParams.get('old_instance');
        const countdownEl = document.getElementById('countdown');
        const iconServer = document.getElementById('icon-server');
        const iconSlideshow = document.getElementById('icon-slideshow');

        let serverIsNew = false;
        let slideshowIsUp = false;

        window.addEventListener('DOMContentLoaded', () => {
            // Si on ne passe pas d'old_instance, on déclenche le reboot (cas du bouton manuel)
            if (!oldInstance) {
                setTimeout(triggerReboot, 100);
            } else {
                rebootTriggered = true;
                startCountdownAndChecks();
            }
        });

        function triggerReboot() {
            if (rebootTriggered) return;
            rebootTriggered = true;
            fetch('/api/trigger_reboot', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            }).catch(() => console.log('Reboot command sent'));
            startCountdownAndChecks();
        }

        function startCountdownAndChecks() {
            // Compteur de sécurité
            const countdownInterval = setInterval(() => {
                remainingTime--;
                if (remainingTime >= 0) {
                    countdownEl.textContent = remainingTime + 's';
                } else {
                    countdownEl.textContent = '⏳';
                }
            }, 1000);

            // Boucle de vérification
            const checkInterval = setInterval(async () => {
                try {
                    const response = await fetch('/api/ping', { cache: 'no-cache' });
                    if (response.ok) {
                        const data = await response.json();
                        
                        // 1. Vérification du Serveur Web (Instance)
                        if (!oldInstance || (data.instance && data.instance !== oldInstance)) {
                            iconServer.className = 'fas fa-check-circle text-green-500';
                            serverIsNew = true;
                        } else {
                            iconServer.className = 'fas fa-spinner fa-spin text-blue-500';
                        }

                        // 2. Vérification du Diaporama
                        if (data.slideshow_running) {
                            iconSlideshow.className = 'fas fa-check-circle text-green-500';
                            slideshowIsUp = true;
                        } else {
                            iconSlideshow.className = 'fas fa-spinner fa-spin text-blue-500';
                            slideshowIsUp = false;
                        }

                        // Redirection finale quand tout est OK
                        if (serverIsNew && slideshowIsUp) {
                            clearInterval(checkInterval);
                            clearInterval(countdownInterval);
                            countdownEl.textContent = '✅';
                            document.querySelector('.info').innerHTML = "Tout est prêt !<br>Redirection en cours...";
                            setTimeout(() => { window.location.href = '/configure'; }, 1500);
                        }
                    }
                } catch (e) {
                    // Le serveur est hors-ligne pendant le reboot
                    iconServer.className = 'fas fa-circle text-red-500';
                    iconSlideshow.className = 'fas fa-circle text-red-500';
                }
            }, 3000);
        }
    </script>
</body>

</html>