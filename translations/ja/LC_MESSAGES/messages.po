#, python-format
msgid "%(count)s photo(s) envoyée(s) pour validation avec succès !"
msgstr "%(count)s 枚の写真が検証のために正常に送信されました。"

#: app.py:784
msgid "Photo rejetée."
msgstr "写真は拒否されました。"

