msgid ""
"Configuration enregistrée. Le diaporama a été relancé pour appliquer les "
"changements."
msgstr "設定が保存されました。変更を適用するためにスライドショーが再開されました。"

#: app.py:1408
msgid "Le token du bot est requis."
msgstr "ボットトークンは必須です。"

#: app.py:1418
#, python-format
msgid "Token valide ! Le bot s'appelle '%(bot_name)s'."
msgstr "有効なトークンです!ボットの名前は「%(bot_name)s」です。"

#: app.py:1421
#, python-format
msgid "Échec de l'envoi : %(error)s"
msgstr "送信に失敗しました: %(error)s"

